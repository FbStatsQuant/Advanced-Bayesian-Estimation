)
}
theta_init_smart <- y
result_gibbs_gamma <- gibbs_gamma_prior(
y = y,
tau = tau,
a = a,
b = b,
gamma = gamma,
D = D,
delta = delta,
gibbs_iter = gibbs_iter,
gibbs_burn = gibbs_burn,
eps = eps,
theta_init = theta_init_smart,
order = order
)
cat("\n=== FINAL GIBBS RESULTS (GAMMA PRIOR) ===\n")
cat("Final lambda estimate (posterior mean):", round(result_gibbs_gamma$lambda_estimate, 2), "\n")
cat("Lambda posterior std:", round(sd(result_gibbs_gamma$lambda_samples), 2), "\n")
cat("Overall acceptance rate:", round(result_gibbs_gamma$acceptance_rate, 3), "\n")
rmse_mean <- sqrt(mean((Q_true - result_gibbs_gamma$theta_mean_estimate)^2))
rmse_median <- sqrt(mean((Q_true - result_gibbs_gamma$theta_median_estimate)^2))
rmse_mode <- sqrt(mean((Q_true - result_gibbs_gamma$theta_mode_estimate)^2))
cat("RMSE Results:\n")
cat("Mean estimate RMSE:", round(rmse_mean, 6), "\n")
cat("Median estimate RMSE:", round(rmse_median, 6), "\n")
cat("Mode estimate RMSE:", round(rmse_mode, 6), "\n\n")
df_plot <- tibble(
x = x,
y = y,
theoretical = Q_true,
mean_estimate = result_gibbs_gamma$theta_mean_estimate,
median_estimate = result_gibbs_gamma$theta_median_estimate,
mode_estimate = result_gibbs_gamma$theta_mode_estimate
)
# PLOT 1: MEAN ESTIMATE
p_mean <- ggplot(df_plot, aes(x = x)) +
geom_point(aes(y = y), alpha = 0.3, color = "gray60", size = 0.5) +
geom_line(aes(y = theoretical), color = "black", size = 1.2) +
geom_line(aes(y = mean_estimate), color = "red", size = 1.0, linetype = "dashed") +
labs(
title = "Gibbs with Gamma Prior: MEAN Estimate",
subtitle = paste("RMSE:", round(rmse_mean, 4), "| λ estimate:", round(result_gibbs_gamma$lambda_estimate, 2)),
x = "x",
y = "Quantile Value"
) +
theme_minimal() +
annotate("text", x = max(x)*0.7, y = max(Q_true)*0.9,
label = "Theoretical (black solid)\nMean estimate (red dashed)",
hjust = 0, size = 3.5)
# PLOT 2: MEDIAN ESTIMATE
