x = "x",
y = "Quantile Value"
) +
theme_minimal() +
annotate("text", x = max(x)*0.7, y = max(Q_true)*0.9,
label = "Theoretical (black solid)\nMedian estimate (blue dashed)",
hjust = 0, size = 3.5)
# PLOT 3: MODE ESTIMATE
